# Instagram / Facebook credentials
INSTAGRAM_ACCESS_TOKEN=your_long_lived_user_access_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# Webhook verification token (you create this — any random string)
WEBHOOK_VERIFY_TOKEN=your_random_verify_token_here

# Database (SQLite for local dev; swap for postgres:// in production)
DATABASE_URL=sqlite:///./app.db
